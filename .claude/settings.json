{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",

      "Bash(cmake -B build*)",
      "Bash(cmake --build build*)",
      "Bash(./build/test_*)",
      "Bash(./build/bench_*)",
      "Bash(./build/chain_replay*)",
      "Bash(./setup.sh*)",

      "Bash(./tools/*.sh*)",
      "Bash(python3 tools/*.py*)",
      "Bash(python3 examples/python/*.py*)",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(nm:*)",
      "Bash(readelf:*)",
      "Bash(ldd:*)",
      "Bash(ps:*)",
      "Bash(pgrep:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo:*)",
      "Bash(chmod -R*)",
      "Bash(chown:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=*)"
    ]
  }
}
